<view class="page theme-{{theme}}">
  <!-- 顶部导航栏（小程序默认导航栏 + 返回按钮） -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回球厅态势</text>
    </view>
  </view>

  <!-- 顶部 banner：三态（trial 不可点 / active 可续费 / expired 可开通） -->
  <view
    wx:if="{{isCurrentUser && !isCoach && bannerMode === 'trial'}}"
    class="trial-banner trial-banner--active"
  >
    <text class="trial-banner__icon">·</text>
    <text class="trial-banner__txt">会员试用期内，还剩 {{trialDays}} 天</text>
  </view>
  <view
    wx:elif="{{isCurrentUser && !isCoach && bannerMode === 'active'}}"
    class="trial-banner trial-banner--active"
    bindtap="onTapProfileBanner"
  >
    <text class="trial-banner__icon">·</text>
    <text class="trial-banner__txt">会员剩余 {{planRemainDays}} 天 · 点此续费</text>
  </view>
  <view
    wx:elif="{{isCurrentUser && !isCoach && plan === 'free' && trialRemaining === 0}}"
    class="trial-expired"
    bindtap="onTapProfileBanner"
  >
    <text class="trial-expired__icon">!</text>
    <text class="trial-expired__txt">试用期已结束，开通会员解锁约球桌 / 约教练 / 数据分析等能力</text>
  </view>

  <!-- 头部信息 -->
  <view class="hero" style="--brand:{{isCoach ? '#e67e22' : '#067EF9'}}">
    <view class="avatar-wrap">
      <image wx:if="{{avatar}}" class="avatar" src="{{avatar}}" mode="aspectFill" />
      <view wx:else class="avatar-ph">{{nickname ? nickname[0] : '?'}}</view>
    </view>
    <view class="hero-name">{{nickname || '未知球员'}}</view>
    <view class="hero-badge {{isCoach ? 'coach' : 'member'}}">
      {{isCoach ? '教练' : '会员'}}
    </view>
  </view>

  <!-- 教练视图 -->
  <view wx:if="{{isCoach}}" class="content">
    <view class="card">
      <view class="card-title">教练简介</view>
      <view class="info-row" wx:if="{{coachYears}}">
        <text class="info-label">教龄</text>
        <text class="info-value">{{coachYears}} 年</text>
      </view>
      <view class="info-row" wx:if="{{pricePerMinute}}">
        <text class="info-label">收费标准</text>
        <text class="info-value accent">{{pricePerMinute}} 元/分钟</text>
      </view>
      <view class="intro-text" wx:if="{{intro}}">{{intro}}</view>
      <view class="muted" wx:if="{{!coachYears && !pricePerMinute && !intro}}">暂无教练信息</view>
    </view>

    <view class="card" wx:if="{{certificates.length > 0}}">
      <view class="card-title">资格证书</view>
      <view class="cert-grid">
        <image class="cert-img" src="{{item}}" mode="aspectFill" wx:for="{{certificates}}" wx:key="*this" />
      </view>
    </view>
  </view>

  <!-- 会员视图 -->
  <view wx:else class="content">
    <!-- 试期已过期且未购买：红色提醒 banner -->
    <view class="card trial-expired" wx:if="{{showTrialExpired}}">
      <view class="trial-expired__title">您的试用期已结束</view>
      <view class="trial-expired__sub">开通会员后可继续使用约球桌、约教练等高级功能</view>
      <view class="trial-expired__btn" bindtap="onOpenPaywall">立即开通</view>
    </view>

    <view class="card">
      <view class="card-title">训练概览</view>
      <view wx:if="{{loading}}" class="loading">加载中...</view>
      <view wx:else>
        <view class="stats-row">
          <view class="stat-item">
            <view class="stat-num">{{totalDays}}</view>
            <view class="stat-label">累计打卡天</view>
          </view>
          <view class="stat-item">
            <view class="stat-num">{{totalHoursText}}</view>
            <view class="stat-label">累计时长(h)</view>
          </view>
          <view class="stat-item">
            <view class="stat-num">{{streak}}</view>
            <view class="stat-label">连续打卡天</view>
          </view>
        </view>
        <view class="muted" wx:if="{{totalDays === 0 && !loading}}">暂无训练记录</view>
      </view>
    </view>

    <!-- 会员中心（仅当前会员用户可见） -->
    <view class="card member-card" wx:if="{{isCurrentUser && !isCoach}}">
      <view class="card-title">会员中心</view>
      <view class="member-status">
        <view class="member-status__row">
          <text class="member-status__label">当前套餐</text>
          <text class="member-status__value {{plan === 'free' ? 'is-free' : 'is-pro'}}">{{planLabel}}</text>
        </view>
        <view class="member-status__row" wx:if="{{trialRemaining > 0}}">
          <text class="member-status__label">试用剩余</text>
          <text class="member-status__value is-trial">{{trialDays}} 天</text>
        </view>
      </view>
      <view class="member-actions">
        <view class="member-btn member-btn--primary" bindtap="onOpenPaywall">开通 / 续费会员</view>
        <view class="member-btn" bindtap="onTryBlockedFeature" wx:if="{{plan === 'free' && trialRemaining === 0}}">体验付费功能</view>
      </view>
    </view>
  </view>

  <!-- 通用付费墙（仅当前用户实例化，避免他人主页弹出） -->
  <paywall id="paywall" wx:if="{{isCurrentUser}}" />
</view>
