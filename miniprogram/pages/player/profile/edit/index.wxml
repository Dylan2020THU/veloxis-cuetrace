<view class="page theme-{{theme}}">
  <view class="form">
    <view class="form-section-title">基本信息</view>

    <!-- 头像 -->
    <view class="form-row avatar-row" bindtap="chooseAvatar">
      <text class="form-label">头像</text>
      <view class="value-area">
        <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-ph">{{nickname ? nickname[0] : '?'}}</view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-row">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>

    <!-- 性别 -->
    <view class="form-row">
      <text class="form-label">性别</text>
      <view class="value-area">
        <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <text class="form-value {{genderOptions[genderIndex] ? '' : 'muted'}}">{{genderOptions[genderIndex] || '请选择'}}</text>
        </picker>
        <switch class="field-switch" checked="{{canSeeGender}}" data-name="canSeeGender" bindchange="onToggleField" color="#067ef9" />
      </view>
    </view>

    <!-- 出生年月 -->
    <view class="form-row">
      <text class="form-label">出生年月</text>
      <view class="value-area">
        <picker mode="date" value="{{birthDate}}" start="1950-01-01" end="2025-12-31" bindchange="onBirthDateChange">
          <text class="form-value {{birthDate ? '' : 'muted'}}">{{birthDate || '请选择'}}</text>
        </picker>
        <switch class="field-switch" checked="{{canSeeBirthDate}}" data-name="canSeeBirthDate" bindchange="onToggleField" color="#067ef9" />
      </view>
    </view>

    <!-- 手机号 -->
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <!-- 所在地 -->
    <view class="form-row">
      <text class="form-label">所在地</text>
      <view class="value-area location-area">
        <text class="form-value {{locationCity ? '' : 'muted'}}">{{locationCity || '请选择'}}</text>
        <view class="location-btns">
          <text class="loc-btn" bindtap="onLocateCity">定位</text>
          <picker class="loc-picker" mode="region" bindchange="onLocationPickerChange">
            <text class="loc-btn">选择</text>
          </picker>
        </view>
      </view>
    </view>

    <!-- 籍贯（省级+市级） -->
    <view class="form-row">
      <text class="form-label">籍贯</text>
      <view class="value-area hometown-pickers">
        <picker mode="selector" range="{{hometownProvinces}}" value="{{hometownProvinceIndex}}" bindchange="onHometownProvinceChange">
          <text class="form-value muted-hometown">{{hometownProvinces[hometownProvinceIndex] || '省'}}</text>
        </picker>
        <text class="picker-sep">/</text>
        <picker mode="selector" range="{{hometownCities}}" value="{{hometownCityIndex}}" bindchange="onHometownCityChange">
          <text class="form-value muted-hometown">{{hometownCities[hometownCityIndex] || '市'}}</text>
        </picker>
        <switch class="field-switch" checked="{{canSeeHometown}}" data-name="canSeeHometown" bindchange="onToggleField" color="#067ef9" />
      </view>
    </view>
  </view>

  <!-- 球技信息 -->
  <view class="form" style="margin-top: 24rpx;">
    <view class="form-section-title">球技信息</view>

    <!-- 球龄 -->
    <view class="form-row">
      <text class="form-label">球龄</text>
      <view class="value-area">
        <picker mode="selector" range="{{yearsOptions}}" value="{{yearsIndex}}" bindchange="onYearsChange">
          <text class="form-value">{{yearsOptions[yearsIndex]}}</text>
        </picker>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 段位 -->
    <view class="form-row">
      <text class="form-label">段位</text>
      <view class="value-area">
        <picker mode="selector" range="{{levels}}" value="{{levelIndex}}" bindchange="onLevelChange">
          <text class="form-value">{{levels[levelIndex]}}</text>
        </picker>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="save" disabled="{{submitting}}">
    {{ submitting ? '保存中...' : '保存' }}
  </button>
</view>
