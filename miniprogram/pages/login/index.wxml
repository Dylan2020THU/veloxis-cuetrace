<view class="page {{theme==='dark'?'theme-dark':''}}">
  <view class="login-wrap">
    <view class="hero">
      <image class="hero-logo" src="/images/login/logo-cuetrace.png" mode="aspectFit"></image>
      <view class="hero-name">强化杆迹</view>
      <view class="hero-slogan">没有任何一杆是白打的</view>
      <view class="hero-sub">{{ step === 1 ? '请选择身份，使用账号或手机号登录' : (mode === 'register' ? '注册「' + roleLabel + '」账号' : '使用「' + roleLabel + '」身份登录') }}</view>
    </view>

    <!-- 第一步：身份选择（库边瞄准点选择器） -->
    <block wx:if="{{step === 1}}">
      <view class="picker-label">选择你的身份</view>
      <view class="roles">
        <view
          wx:for="{{roles}}"
          wx:key="key"
          class="role-row {{role===item.key?'active':''}}"
          data-role="{{item.key}}"
          bindtap="selectRole"
        >
          <view class="sight"></view>
          <image class="role-thumb" src="{{item.img}}" mode="aspectFill" lazy-load="true"></image>
          <view class="role-info">
            <view class="role-label">{{item.label}}</view>
            <view class="role-desc">{{item.desc}}</view>
          </view>
          <view class="role-arrow">›</view>
        </view>
      </view>

      <button class="btn-primary next-btn" bindtap="goNext">登录 · {{roleLabel}}</button>

      <view wx:if="{{role==='shop'}}" class="shop-tip">店主注册需核验「营业执照」等信息，提交后经平台审核通过方可使用</view>
    </block>

    <!-- 第二步：账号登录 -->
    <block wx:else>
      <view class="step2-head">
        <view class="back" bindtap="goPrev">‹ 返回</view>
        <view class="cur-role">当前身份：{{roleLabel}}</view>
      </view>

      <view class="login-card">
      <block wx:if="{{mode==='login'}}">
      <!-- 登录方式切换 -->
      <view class="seg">
        <view
          class="seg-item {{loginType==='password'?'active':''}}"
          data-type="password"
          bindtap="switchType"
        >账号登录</view>
        <view
          class="seg-item {{loginType==='sms'?'active':''}}"
          data-type="sms"
          bindtap="switchType"
        >手机号登录</view>
      </view>

      <!-- 账号密码登录 -->
      <block wx:if="{{loginType==='password'}}">
        <view class="field">
          <input
            class="input"
            placeholder="请输入账号"
            placeholder-class="placeholder"
            data-field="account"
            value="{{account}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请输入密码"
            placeholder-class="placeholder"
            data-field="password"
            value="{{password}}"
            bindinput="onInput"
          />
        </view>
      </block>

      <!-- 手机验证码登录 -->
      <block wx:else>
        <view class="field">
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            placeholder-class="placeholder"
            data-field="phone"
            value="{{phone}}"
            bindinput="onInput"
          />
        </view>
        <view class="field field-code">
          <input
            class="input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            placeholder-class="placeholder"
            data-field="code"
            value="{{code}}"
            bindinput="onInput"
          />
          <view class="code-btn {{counting?'disabled':''}}" bindtap="sendCode">
            {{counting ? countdown + 's' : '获取验证码'}}
          </view>
        </view>
      </block>

      <button class="btn-primary login-btn" bindtap="submit">登录</button>

      <view class="alt-line">
        <text class="alt-text">还没有账号？</text>
        <text class="alt-link" bindtap="goRegister">注册账号</text>
      </view>

      <view class="other-login">
        <view class="other-title">其他登录方式</view>
        <button class="wechat-icon-btn" bindtap="wechatLogin">
          <view class="wechat-logo" aria-hidden="true">
            <view class="wechat-logo-bubble main">
              <view class="wechat-dot dot-a"></view>
              <view class="wechat-dot dot-b"></view>
            </view>
            <view class="wechat-logo-bubble sub">
              <view class="wechat-dot dot-c"></view>
              <view class="wechat-dot dot-d"></view>
            </view>
          </view>
        </button>
      </view>
      </block>

      <!-- 注册态 -->
      <block wx:else>
        <view class="field">
          <input
            class="input"
            placeholder="请输入账号"
            placeholder-class="placeholder"
            data-field="regAccount"
            value="{{regAccount}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请设置密码（至少 6 位）"
            placeholder-class="placeholder"
            data-field="regPassword"
            value="{{regPassword}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请再次输入密码"
            placeholder-class="placeholder"
            data-field="regConfirm"
            value="{{regConfirm}}"
            bindinput="onInput"
          />
        </view>

        <button class="btn-primary login-btn" bindtap="register">注册</button>

        <view class="alt-line">
          <text class="alt-text">已有账号？</text>
          <text class="alt-link" bindtap="backToLogin">返回登录</text>
        </view>
      </block>
      </view>
    </block>
  </view>
</view>
