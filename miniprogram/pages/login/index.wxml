<view class="page {{theme==='dark'?'theme-dark':''}}">
  <view class="login-wrap">
    <view class="hero">
      <image class="hero-logo" src="/images/login/logo-cuetrace.png" mode="aspectFit"></image>
      <view class="hero-name">强化杆迹</view>
      <view class="hero-slogan">没有任何一杆是白打的</view>
      <view class="hero-sub">{{ step === 'role' ? '请选择本次进入的身份' : (mode === 'register' ? '注册账号' : (mode === 'wechatBind' ? '绑定当前微信' : (mode === 'recover' ? '找回密码' : '使用账号或手机号登录'))) }}</view>
    </view>

    <!-- 账号验证通过后选择本次进入身份 -->
    <block wx:if="{{step === 'role'}}">
      <view class="step2-head">
        <view class="back" bindtap="goPrev">‹ 返回登录</view>
      </view>
      <view class="picker-label">选择进入身份</view>
      <view class="roles">
        <view
          wx:for="{{availableRoles}}"
          wx:key="key"
          class="role-row {{role===item.key?'active':''}} {{item.enabled?'':'locked'}}"
          data-role="{{item.key}}"
          bindtap="chooseRole"
        >
          <view class="sight"></view>
          <image class="role-thumb" src="{{item.img}}" mode="aspectFill" lazy-load="true"></image>
          <view class="role-info">
            <view class="role-label">{{item.label}}</view>
            <view class="role-desc">{{item.desc}}</view>
          </view>
          <view class="role-arrow">›</view>
          <view wx:if="{{!item.enabled}}" class="role-lock">
            <view class="role-lock-text">未开通</view>
          </view>
        </view>
      </view>
      <button class="btn-primary next-btn role-enter-btn" bindtap="enterSelectedRole">进入</button>
    </block>

    <!-- 账号登录 -->
    <block wx:elif="{{step === 'auth'}}">
      <view class="step2-head" wx:if="{{false}}">
        <view class="back" bindtap="goPrev">‹ 返回</view>
        <view class="cur-role">当前身份：{{roleLabel}}</view>
      </view>

      <view class="login-card">
      <block wx:if="{{mode==='login'}}">
      <!-- 登录方式切换 -->
      <view class="seg">
        <view
          class="seg-item {{loginType==='password'?'active':''}}"
          data-type="password"
          bindtap="switchType"
        >账号登录</view>
        <view
          class="seg-item {{loginType==='sms'?'active':''}}"
          data-type="sms"
          bindtap="switchType"
        >手机号登录</view>
      </view>

      <!-- 账号密码登录 -->
      <block wx:if="{{loginType==='password'}}">
        <view class="field">
          <input
            class="input"
            placeholder="请输入账号"
            placeholder-class="placeholder"
            data-field="account"
            value="{{account}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请输入密码"
            placeholder-class="placeholder"
            data-field="password"
            value="{{password}}"
            bindinput="onInput"
          />
        </view>
        <view class="forgot-line">
          <text class="forgot-link" bindtap="openRecovery">忘记密码</text>
        </view>
      </block>

      <!-- 手机验证码登录 -->
      <block wx:else>
        <view class="field">
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            placeholder-class="placeholder"
            data-field="phone"
            value="{{phone}}"
            bindinput="onInput"
          />
        </view>
        <view class="field field-code">
          <input
            class="input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            placeholder-class="placeholder"
            data-field="code"
            value="{{code}}"
            bindinput="onInput"
          />
          <view class="code-btn {{counting?'disabled':''}}" bindtap="sendCode">
            {{counting ? countdown + 's' : '获取验证码'}}
          </view>
        </view>
      </block>

      <view class="agreement-row">
        <view class="agree-circle {{agreementChecked ? 'checked' : ''}}" bindtap="toggleAgreement">
          <text wx:if="{{agreementChecked}}" class="agree-check">✓</text>
        </view>
        <view class="agree-text">
          <text>我已阅读并同意</text>
          <text class="agree-link" catchtap="openAgreement">《强化杆迹用户协议》</text>
          <text>和</text>
          <text class="agree-link" catchtap="openPrivacyPolicy">《强化杆迹隐私权政策》</text>
        </view>
      </view>

      <button class="btn-primary login-btn {{agreementChecked ? '' : 'login-btn--disabled'}}" bindtap="submit">登录</button>

      <view class="alt-line">
        <text class="alt-text">还没有账号？</text>
        <text class="alt-link" bindtap="goRegister">注册账号</text>
      </view>

      <view class="other-login">
        <view class="other-title">其他登录方式</view>
        <button class="wechat-icon-btn" bindtap="wechatLogin">
          <image class="wechat-logo-img" src="/images/login/WeChat_logo.ico" mode="aspectFit"></image>
        </button>
      </view>
      </block>

      <!-- 微信未绑定引导态 -->
      <block wx:elif="{{mode==='wechatBind'}}">
        <view class="bind-head">
          <view class="bind-title">当前微信尚未绑定账号</view>
          <view class="bind-sub">请使用账号密码验证后绑定当前微信；每个账号和微信只能绑定一次</view>
        </view>

        <button class="btn-primary login-btn" bindtap="backToLogin">使用账号密码登录</button>

        <view class="alt-line">
          <text class="alt-text">还没有账号？</text>
          <text class="alt-link" bindtap="goRegister">注册账号</text>
        </view>
      </block>

      <!-- 注册态 -->
      <block wx:elif="{{mode === 'register'}}">
        <view class="field">
          <input
            class="input"
            placeholder="请输入账号"
            placeholder-class="placeholder"
            data-field="regAccount"
            value="{{regAccount}}"
            bindinput="onInput"
          />
        </view>
        <view class="account-rule">{{accountRuleText}}</view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请设置密码（至少 6 位）"
            placeholder-class="placeholder"
            data-field="regPassword"
            value="{{regPassword}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请再次输入密码"
            placeholder-class="placeholder"
            data-field="regConfirm"
            value="{{regConfirm}}"
            bindinput="onInput"
          />
        </view>

        <view class="agreement-row agreement-row--register">
          <view class="agree-circle {{agreementChecked ? 'checked' : ''}}" bindtap="toggleAgreement">
            <text wx:if="{{agreementChecked}}" class="agree-check">✓</text>
          </view>
          <view class="agree-text">
            <text>我已阅读并同意</text>
            <text class="agree-link" catchtap="openAgreement">《强化杆迹用户协议》</text>
            <text>和</text>
            <text class="agree-link" catchtap="openPrivacyPolicy">《强化杆迹隐私权政策》</text>
          </view>
        </view>

        <button class="btn-primary login-btn {{agreementChecked ? '' : 'login-btn--disabled'}}" bindtap="register">注册</button>

        <view class="alt-line">
          <text class="alt-text">已有账号？</text>
          <text class="alt-link" bindtap="backToLogin">返回登录</text>
        </view>
      </block>

      <!-- 密码找回态 -->
      <block wx:elif="{{mode === 'recover'}}">
        <view class="seg recovery-seg">
          <view
            class="seg-item {{recoveryType === 'wechat' ? 'active' : ''}}"
            data-type="wechat"
            bindtap="switchRecoveryType"
          >微信找回</view>
          <view
            class="seg-item {{recoveryType === 'email' ? 'active' : ''}}"
            data-type="email"
            bindtap="switchRecoveryType"
          >邮箱找回</view>
        </view>

        <view wx:if="{{recoveryType === 'wechat'}}" class="recovery-tip">
          使用当前微信验证身份，只会重置该微信已绑定账号的密码
        </view>

        <block wx:if="{{recoveryType === 'email'}}">
          <view class="field">
            <input
              class="input"
              placeholder="请输入账号"
              placeholder-class="placeholder"
              data-field="recoveryAccount"
              value="{{recoveryAccount}}"
              bindinput="onInput"
            />
          </view>
          <view class="field">
            <input
              class="input"
              placeholder="请输入已绑定邮箱"
              placeholder-class="placeholder"
              data-field="recoveryEmail"
              value="{{recoveryEmail}}"
              bindinput="onInput"
            />
          </view>
          <view class="field field-code">
            <input
              class="input"
              type="number"
              maxlength="6"
              placeholder="请输入验证码"
              placeholder-class="placeholder"
              data-field="recoveryCode"
              value="{{recoveryCode}}"
              bindinput="onInput"
            />
            <view
              class="code-btn {{recoveryCounting || recoverySending ? 'disabled' : ''}}"
              bindtap="sendRecoveryEmailCode"
            >{{recoverySending ? '发送中' : (recoveryCounting ? recoveryCountdown + 's' : '获取验证码')}}</view>
          </view>
        </block>

        <view class="field">
          <input
            class="input"
            password
            placeholder="请输入新密码（至少 6 位）"
            placeholder-class="placeholder"
            data-field="recoveryPassword"
            value="{{recoveryPassword}}"
            bindinput="onInput"
          />
        </view>
        <view class="field">
          <input
            class="input"
            password
            placeholder="请再次输入新密码"
            placeholder-class="placeholder"
            data-field="recoveryConfirm"
            value="{{recoveryConfirm}}"
            bindinput="onInput"
          />
        </view>

        <button class="btn-primary login-btn" disabled="{{recoverySubmitting}}" bindtap="submitRecovery">{{recoverySubmitting ? '提交中' : '重置密码'}}</button>

        <view class="alt-line">
          <text class="alt-link alt-link--solo" bindtap="backToLogin">返回登录</text>
        </view>
      </block>
      </view>
    </block>
  </view>
  <view wx:if="{{step === 'auth'}}" class="icp-footer">京ICP备2026039244号-1X</view>
</view>
