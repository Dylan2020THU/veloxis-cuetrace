.page {
  min-height: 100vh;
  background: var(--bg);
  /* 登录页专属强调色：黄铜(库边瞄准点) + 深川(渐变深端) */
  --brass: #C9A24B;
  --deep: #0B3C82;
}

.login-wrap {
  padding: 80rpx 48rpx 60rpx;
}

/* 品牌 Hero：川蓝 → 深川 渐变 */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(160deg, var(--brand) 0%, var(--deep) 100%);
  border-radius: 32rpx;
  padding: 56rpx 40rpx 46rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 16rpx 40rpx rgba(11, 60, 130, 0.28);
}
.hero-logo {
  width: 104rpx;
  height: 104rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}
.hero-name {
  margin-top: 22rpx;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #fff;
}
.hero-slogan {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: #fff;
}
.hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

/* 选身份小标题 */
.picker-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-sub);
  margin: 0 8rpx 24rpx;
}

/* 身份选择：库边瞄准点选择器 */
.roles {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}
.role-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}
/* 库边菱形瞄准点：描边=未选，铜色实心=选中 */
.sight {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  transform: rotate(45deg);
  border: 3rpx solid var(--brass);
  border-radius: 4rpx;
  background: transparent;
  transition: all 0.2s ease;
}
.role-thumb {
  width: 92rpx;
  height: 92rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  border-radius: 16rpx;
  background: var(--bg-elev);
}
.role-info {
  flex: 1;
}
.role-label {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 2rpx;
}
.role-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-weak);
}
.role-arrow {
  font-size: 36rpx;
  color: var(--text-weak);
  margin-left: 12rpx;
}
/* 选中态：铜色瞄准锁定 */
.role-row.active {
  border-color: var(--brass);
  box-shadow: 0 6rpx 24rpx rgba(201, 162, 75, 0.2);
}
.role-row.active .sight {
  background: var(--brass);
  box-shadow: 0 0 0 6rpx rgba(201, 162, 75, 0.18);
}

/* 第一步：下一步按钮 */
.next-btn {
  margin-top: 8rpx;
  height: 92rpx;
  border-radius: 36rpx 0 36rpx 0;
}

/* 店主身份：登录按钮下方的资质核验提示 */
.shop-tip {
  margin: 24rpx 16rpx 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #e54545;
  text-align: center;
}

/* 第二步：顶部返回 + 当前身份 */
.step2-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.back {
  font-size: 30rpx;
  color: var(--brand);
  font-weight: 500;
}
.cur-role {
  font-size: 26rpx;
  color: var(--text-weak);
}

/* 登录表单卡片：玻璃拟态 + 电光蓝顶部光晕 */
.login-card {
  position: relative;
  background: var(--card-bg);
  border: 2rpx solid var(--border);
  border-radius: 28rpx;
  padding: 44rpx 32rpx 48rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}
.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, rgba(6, 126, 249, 0) 0%, var(--brand-3) 50%, rgba(6, 126, 249, 0) 100%);
}

.seg {
  display: flex;
  background: var(--bg-elev);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 36rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: var(--text-sub);
  border-radius: 12rpx;
  transition: all 0.2s;
}
.seg-item.active {
  background: var(--card-bg);
  color: var(--brand);
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(6, 126, 249, 0.18);
}

/* 圆角填充式输入框 */
.field {
  display: flex;
  align-items: center;
  height: 92rpx;
  margin-bottom: 24rpx;
  padding: 0 28rpx;
  background: var(--bg-elev);
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
}
.input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}
.placeholder {
  color: var(--text-weak);
}

.field-code .input {
  margin-right: 24rpx;
}
.code-btn {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--brand);
  padding: 12rpx 24rpx;
  border: 2rpx solid var(--brand);
  border-radius: 36rpx 0 36rpx 0;
}
.code-btn.disabled {
  color: var(--text-weak);
  border-color: var(--border);
}

.login-btn {
  margin-top: 48rpx;
  height: 92rpx;
  border-radius: 36rpx 0 36rpx 0;
  box-shadow: 0 10rpx 28rpx rgba(6, 126, 249, 0.35);
}

/* 登录 / 注册 切换链接 */
.alt-line {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
}
.alt-text {
  font-size: 26rpx;
  color: var(--text-weak);
}
.alt-link {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
  margin-left: 6rpx;
}
