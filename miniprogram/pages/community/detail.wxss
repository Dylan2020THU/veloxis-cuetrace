.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #8a9099;
  font-size: 26rpx;
}

.page {
  padding-bottom: 160rpx;
}

.media {
  width: 100%;
  background: #000;
}

.video {
  width: 100%;
  height: 480rpx;
}

.media-swiper {
  width: 100%;
  height: 750rpx;
  background: #000;
}

.swiper-img {
  width: 100%;
  height: 750rpx;
}

.content-card {
  background: #fff;
  padding: 28rpx 32rpx;
}

.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.a-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(6, 126, 249, 0.12);
  color: #067ef9;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.a-info {
  flex: 1;
}

.a-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.a-time {
  font-size: 22rpx;
  color: #8a9099;
  margin-top: 4rpx;
}

.follow-btn {
  font-size: 26rpx;
  color: #fff;
  background: #067ef9;
  padding: 10rpx 28rpx;
  border-radius: 36rpx 0 36rpx 0;
  line-height: 1;
}

.follow-btn.following {
  background: #f4f6f8;
  color: #8a9099;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 16rpx;
}

.content {
  font-size: 30rpx;
  color: #2b3138;
  line-height: 1.7;
  white-space: pre-wrap;
}

.comments-card {
  background: #fff;
  margin-top: 20rpx;
  padding: 28rpx 32rpx;
}

.comments-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 20rpx;
}

.no-comment {
  padding: 30rpx 0;
  text-align: center;
}

.comment {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.comment:last-child {
  border-bottom: none;
}

.c-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #eef1f4;
  color: #8a9099;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex: 0 0 60rpx;
}

.c-main {
  flex: 1;
}

.c-name {
  font-size: 26rpx;
  color: #8a9099;
}

.c-text {
  font-size: 30rpx;
  color: #1f2329;
  margin: 6rpx 0;
  line-height: 1.5;
}

.c-time {
  font-size: 22rpx;
  color: #b6bcc2;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f4f6f8;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  margin: 0 20rpx;
}

.like-btn .heart {
  font-size: 44rpx;
  color: #c4c9ce;
}

.like-btn.liked .heart {
  color: #ff5a79;
}

.like-num {
  font-size: 24rpx;
  color: #8a9099;
  margin-left: 6rpx;
}

.send-btn {
  background: #067ef9;
  color: #fff;
  font-size: 28rpx;
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 36rpx 0 36rpx 0;
}

.send-btn[disabled] {
  background: #b7d6ff;
}
