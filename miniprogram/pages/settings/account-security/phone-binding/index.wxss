.page {
  min-height: 100vh;
  padding: 28rpx 24rpx;
}

.card {
  padding: 32rpx;
  border-radius: 20rpx;
  background: var(--card-bg);
}

.label {
  display: block;
  margin-bottom: 16rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 600;
}

input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.code-row input {
  flex: 1;
}

.code-row button {
  flex-shrink: 0;
  margin: 0;
  font-size: 26rpx;
}

.hint {
  display: block;
  margin: 16rpx 0 28rpx;
  color: var(--text-weak);
  font-size: 26rpx;
}

.display-value {
  color: var(--text);
  font-size: 32rpx;
}

.submit {
  color: #fff;
  background: #067ef9;
}
