<view class="page theme-{{theme}}">
  <view class="card">
    <view wx:if="{{displayOnly}}" class="display-value">
      <text class="label">已绑定手机号</text>
      <text>{{phoneMasked || '已绑定'}}</text>
      <text class="hint">手机号绑定后暂不支持更换</text>
    </view>
    <block wx:else>
      <text class="label">绑定手机号</text>
      <input type="number" maxlength="11" value="{{phone}}" placeholder="请输入手机号" bindinput="onPhoneInput" />
      <view class="code-row">
        <input type="number" maxlength="6" value="{{code}}" placeholder="验证码" bindinput="onCodeInput" />
        <button disabled="{{sending || counting}}" bindtap="sendCode">{{counting ? countdown + 's' : sending ? '发送中' : '获取验证码'}}</button>
      </view>
      <text class="hint">手机号仅可绑定一次</text>
      <button class="submit" disabled="{{!statusReady || binding}}" bindtap="submit">{{binding ? '提交中' : '确认绑定'}}</button>
    </block>
  </view>
  <recent-auth visible="{{recentAuthVisible}}" methods="{{recentAuthMethods}}" bind:authenticated="onRecentAuthenticated" bind:cancel="onRecentCancel" />
</view>
