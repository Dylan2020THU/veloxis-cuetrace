.page {
  min-height: 100vh;
  padding: 28rpx 24rpx;
}

.card {
  padding: 32rpx;
  border-radius: 20rpx;
  background: var(--card-bg);
}

.title {
  margin-bottom: 24rpx;
  color: var(--text);
  font-size: 34rpx;
  font-weight: 600;
}

input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
}

.hint {
  display: block;
  margin: 0 0 28rpx;
  color: var(--text-weak);
  font-size: 26rpx;
}

button {
  color: #fff;
  background: #067ef9;
}
