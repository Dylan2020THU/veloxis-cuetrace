.profile-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #20242a;
}

.profile-role {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #067ef9;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f4;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #667085;
}

.info-value {
  font-size: 28rpx;
  color: #20242a;
  font-weight: 600;
}

.danger-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #ef4444;
  font-size: 28rpx;
}

.danger-btn::after {
  border: none;
}
