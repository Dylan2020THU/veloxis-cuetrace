.page {
  min-height: 100vh;
  background: #f4f6f8;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.admin-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #20242a;
}

.logout-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #ef4444;
  font-size: 24rpx;
}

.logout-btn::after {
  border: none;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #20242a;
  margin-bottom: 18rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.overview-item {
  min-width: 0;
  padding: 22rpx 8rpx;
  border-radius: 12rpx;
  background: #f7f9fc;
  text-align: center;
}

.overview-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #067ef9;
  line-height: 1.1;
}

.overview-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7b8494;
  white-space: normal;
}

.search {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #f4f6f8;
  font-size: 26rpx;
  color: #20242a;
  box-sizing: border-box;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f4f6f8;
  color: #667085;
  font-size: 24rpx;
}

.chip.active {
  background: #e7f2ff;
  color: #067ef9;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.review-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: #067ef9;
  color: #fff;
  font-size: 24rpx;
}

.review-btn::after {
  border: none;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.row {
  padding: 20rpx;
  border: 1rpx solid #edf0f4;
  border-radius: 14rpx;
}

.row-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row-title {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #20242a;
}

.row-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b8494;
  line-height: 1.5;
}

.row-meta {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #667085;
  font-size: 22rpx;
}

.tag.ok {
  background: #dcfce7;
  color: #15803d;
}

.tag.warn {
  background: #fef3c7;
  color: #a16207;
}

.tag.bad {
  background: #fee2e2;
  color: #b91c1c;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e7f2ff;
  flex-shrink: 0;
}

.person-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.empty,
.error,
.loading {
  padding: 60rpx 20rpx;
  text-align: center;
  color: #9aa0a6;
  font-size: 26rpx;
}

.error {
  color: #ef4444;
}

.admin-bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #edf0f4;
  display: flex;
  align-items: center;
}

.admin-tab {
  flex: 1;
  text-align: center;
  color: #9aa0a6;
  font-size: 24rpx;
  line-height: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.admin-tab.active {
  color: #067ef9;
  font-weight: 700;
}

.admin-tab-icon {
  width: 42rpx;
  height: 42rpx;
  background: currentColor;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: 42rpx 42rpx;
  mask-size: 42rpx 42rpx;
}

.admin-tab-text {
  display: block;
  font-size: 22rpx;
}

