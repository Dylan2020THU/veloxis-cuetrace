/* 底部留白：避免最后一张卡片被固定底栏遮挡 */
.page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* 1. 身份头部 */
.profile-head {
  position: relative;
  background: linear-gradient(135deg, #067ef9 0%, #2b97ff 100%);
  color: #fff;
  padding: 60rpx 40rpx 56rpx;
  text-align: center;
}
.head-gear {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.gear-ic {
  width: 44rpx;
  height: 44rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 44rpx 44rpx;
  background-image: url("data:image/svg+xml;base64,");
}
.head-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: block;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.25);
}
.head-avatar--ph {
  line-height: 124rpx;
  font-size: 56rpx;
  font-weight: 700;
}
.head-name {
  font-size: 38rpx;
  font-weight: 700;
}
.head-role {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

/* 卡片小标题 */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24rpx;
}

/* 2. 训练统计 */
.rank-stats {
  display: flex;
}
.rank-stat {
  flex: 1;
  text-align: center;
}
.rank-stat__num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand);
}
.rank-stat__label {
  font-size: 22rpx;
  color: var(--text-weak);
  margin-top: 6rpx;
}

/* 3 & 4. 四宫格 */
.grid4 {
  display: flex;
}
.grid4-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}
.grid4-num {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}
.grid4-label {
  font-size: 24rpx;
  color: var(--text-weak);
  margin-top: 8rpx;
}

/* 快捷功能：线性图标 */
.quick-ic {
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 44rpx 44rpx;
}
.quick-ic--train {
  background-image: url("data:image/svg+xml;base64,");
}
.quick-ic--community {
  background-image: url("data:image/svg+xml;base64,");
}
.quick-ic--ball {
  background-image: url("data:image/svg+xml;base64,");
}
.quick-ic--edit {
  background-image: url("data:image/svg+xml;base64,");
}

/* 列表项 */
.entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.entry:last-child {
  border-bottom: none;
}
.entry-title {
  font-size: 30rpx;
  color: var(--text);
}
.arrow {
  color: var(--text-weak);
  font-size: 36rpx;
}
