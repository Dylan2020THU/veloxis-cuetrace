<view class="page theme-{{theme}}">
  <view class="profile-head">
    <view class="avatar">{{nickname[0]}}</view>
    <view class="name">{{nickname}}</view>
    <view class="role">大川激流 · {{roleLabel}}</view>
  </view>

  <view class="card">
    <view class="row">
      <text class="row-label">运行模式</text>
      <text class="row-value">{{ cloudReady ? '云开发' : '本地演示数据' }}</text>
    </view>
    <view class="row">
      <text class="row-label">用户标识</text>
      <text class="row-value ellipsis">{{openid}}</text>
    </view>
    <view class="row">
      <text class="row-label">当前身份</text>
      <view class="row-value switch-line" bindtap="switchRole">
        <text class="role-tag {{ role !== 'member' ? 'active' : '' }}">{{roleLabel}}</text>
        <text class="switch-text">点击切换</text>
      </view>
    </view>
    <view class="row" bindtap="switchTheme">
      <text class="row-label">背景模式</text>
      <view class="row-value switch-line">
        <text class="theme-val">{{themeModeLabel}}</text>
        <text class="switch-text">点击切换</text>
      </view>
    </view>
  </view>

  <!-- 教练工作台：仅教练身份可见，会员看不到教练界面 -->
  <view wx:if="{{isCoach}}" class="card">
    <view class="section-title">教练工作台</view>
    <view class="entry" bindtap="goCoachProfile">
      <text class="entry-title">我的教练资料</text>
      <text class="arrow">›</text>
    </view>
    <view class="entry" bindtap="goCoachMembers">
      <text class="entry-title">我的学员</text>
      <text class="arrow">›</text>
    </view>
    <view class="entry" bindtap="goCoachBookings">
      <text class="entry-title">谁约了我</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 店家工作台：仅店家身份可见 -->
  <view wx:elif="{{isShop}}" class="card">
    <view class="section-title">店家工作台</view>
    <view class="entry" bindtap="goShopDashboard">
      <text class="entry-title">店铺管理台</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 会员身份 -->
  <view wx:else class="card">
    <view class="entry" bindtap="goEditProfile">
      <text class="entry-title">编辑我的信息</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="card">
    <button class="logout-btn" bindtap="logout">退出账号</button>
  </view>
</view>
