.page {
  padding-bottom: 320rpx;
}

.form-tip {
  margin: 8rpx 0 24rpx;
}

.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.field:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 30rpx;
  color: var(--text);
  flex: 0 0 140rpx;
}

.field-value {
  font-size: 30rpx;
  color: var(--text);
  text-align: right;
}

.arrow {
  color: var(--text-weak);
  margin-left: 8rpx;
}

.duration-input {
  display: flex;
  align-items: center;
}

.num-input {
  width: 96rpx;
  height: 64rpx;
  background: var(--bg-elev);
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  margin: 0 8rpx;
}

.unit {
  font-size: 26rpx;
  color: var(--text-weak);
  margin-right: 12rpx;
}

.tips-card {
  padding-bottom: 16rpx;
}

.tip-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: var(--text);
}

.tip-cell {
  width: 28rpx;
  height: 28rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}

.tip-cell.l1 {
  background: rgba(6, 126, 249, 0.35);
}

.tip-cell.l2 {
  background: rgba(6, 126, 249, 0.65);
}

.tip-cell.l3 {
  background: rgba(6, 126, 249, 1);
}

.tip-cell.manual {
  background: #b9c0c9;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  z-index: 900;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.92);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
}

/* 夜间模式：底部悬浮提交栏半透明面板 */
.theme-dark .submit-bar {
  background: rgba(28, 30, 36, 0.92);
}
