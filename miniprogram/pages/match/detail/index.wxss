.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

.loading, .empty {
  text-align: center;
  color: var(--text-weak);
  padding: 100rpx 40rpx;
  font-size: 26rpx;
}

.detail-card {
  margin: 24rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #067ef9;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.match-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.match-meta {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.match-meta .name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.tag {
  font-size: 22rpx;
  color: #067ef9;
  background: rgba(6, 126, 249, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.tag.red {
  color: #f5503e;
  background: rgba(245, 80, 62, 0.1);
}

.tag.blue {
  color: #067ef9;
  background: rgba(6, 126, 249, 0.1);
}

.join-num {
  font-size: 22rpx;
  color: var(--text-weak);
  flex-shrink: 0;
}

.row {
  display: flex;
  font-size: 28rpx;
  margin-top: 14rpx;
}

.row .lbl {
  color: var(--text-weak);
  width: 90rpx;
}

.row .val {
  color: var(--text);
  flex: 1;
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.badge {
  font-size: 22rpx;
  color: var(--text-weak);
  background: var(--bg-elev);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.note {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-sub);
  background: var(--bg-elev);
  border-radius: 12rpx;
  padding: 20rpx;
  line-height: 1.6;
}

.joiner-list {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.joiner-title {
  font-size: 26rpx;
  color: var(--text-weak);
  margin-bottom: 16rpx;
}

.joiner-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.joiner-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-elev);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.joiner-avatar image {
  width: 100%;
  height: 100%;
}

.joiner-avatar.placeholder {
  background: #067ef9;
  color: #fff;
  font-size: 26rpx;
}

/* 底部固定操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  text-align: center;
  background: #067ef9;
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 36rpx 0 36rpx 0;
}
