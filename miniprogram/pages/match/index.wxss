.page {
  min-height: 100vh;
  background: #f4f6f8;
  padding-bottom: 180rpx; /* 让出 tabBar 高度 + FAB 底部空间 */
}

/* 顶部栏 */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 12rpx;
  background: #fff;
}
.topbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2329;
}
.mine-entry {
  font-size: 26rpx;
  color: #067ef9;
}

/* 顶部三板块 */
.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 30rpx;
  color: #6b7075;
  position: relative;
}
.tab.active {
  color: #067ef9;
  font-weight: 600;
}
.tab .bar {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #067ef9;
}

.loading {
  text-align: center;
  color: #9aa0a6;
  padding: 60rpx 0;
  font-size: 26rpx;
}
.empty {
  text-align: center;
  color: #9aa0a6;
  padding: 100rpx 40rpx;
  font-size: 26rpx;
}

.list {
  padding: 20rpx 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

/* 头像 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #067ef9;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
/* 人像图片头像 */
image.avatar {
  background: #f0f1f3;
}
.avatar.big {
  width: 96rpx;
  height: 96rpx;
  font-size: 40rpx;
  flex-shrink: 0;
}

/* 约球友卡片 */
.match-head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.match-meta {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.match-meta .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}
.tag {
  font-size: 22rpx;
  color: #067ef9;
  background: rgba(6, 126, 249, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.tag.green {
  color: #00b578;
  background: rgba(0, 181, 120, 0.1);
}
/* 发布者段位：红色 */
.tag.red {
  color: #f5503e;
  background: rgba(245, 80, 62, 0.1);
}
/* 期望段位：蓝色 */
.tag.blue {
  color: #067ef9;
  background: rgba(6, 126, 249, 0.1);
}
.join-num {
  font-size: 22rpx;
  color: #9aa0a6;
}
.row {
  display: flex;
  font-size: 26rpx;
  margin-top: 8rpx;
}
.row .lbl {
  color: #9aa0a6;
  width: 90rpx;
}
.row .val {
  color: #1f2329;
  flex: 1;
}
.note {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #4b5056;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
}
.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
.badge {
  font-size: 22rpx;
  color: #9aa0a6;
  background: #f2f3f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.card.match {
  position: relative;
  padding-bottom: 88rpx;
}

.join-btn {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  text-align: center;
  background: #067ef9;
  color: #fff;
  font-size: 28rpx;
  padding: 18rpx 0;
  border-radius: 36rpx 0 36rpx 0;
  margin-top: 0;
}

/* 约教练 / 约球桌卡片 */
.card.coach,
.card.table {
  display: flex;
  align-items: center;
}
.coach-info,
.table-info {
  flex: 1;
  margin-left: 16rpx;
}

/* 约球桌门店头像框：圆角正方形 */
.table-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f0f1f3;
}
.table-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #067ef9;
  color: #fff;
  font-size: 40rpx;
}
.name-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.name-line .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}
.name-line .price {
  font-size: 26rpx;
  color: #f5503e;
  font-weight: 600;
}
.sub {
  font-size: 24rpx;
  color: #6b7075;
  margin-top: 8rpx;
}
.sub.light {
  color: #9aa0a6;
}
.intro {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-top: 6rpx;
}
.book-btn {
  flex-shrink: 0;
  margin-left: 16rpx;
  background: #067ef9;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 36rpx 0 36rpx 0;
}

/* 悬浮发布 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #067ef9;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(6, 126, 249, 0.4);
  z-index: 9999;
}

/* 预约弹窗 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: center;             /* 改：居中显示，避开底部 TabBar */
  justify-content: center;        /* 新增：水平居中 */
  padding: 0 32rpx;               /* 新增：左右留白 */
}
.sheet {
  width: 100%;
  max-width: 640rpx;              /* 新增：最大宽度，防止太宽 */
  max-height: 80vh;               /* 新增：最大高度，超出滚动 */
  background: #fff;
  border-radius: 24rpx;           /* 改：全圆角（之前顶部圆角是底部抽屉） */
  padding: 32rpx 32rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);  /* 新增：阴影 */
  overflow-y: auto;               /* 新增：内容多时可滚 */
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  text-align: center;
  margin-bottom: 24rpx;
}
.sheet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
  font-size: 28rpx;
}
.sheet-row .lbl {
  color: #6b7075;
  min-width: 140rpx;
  flex-shrink: 0;
}
.sheet-row .val {
  color: #1f2329;
  flex: 1;
  text-align: right;
}
.sheet-row .val.highlight {
  color: #f5503e;
  font-weight: 600;
  font-size: 30rpx;
}
.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 36rpx 0 36rpx 0;
  font-size: 30rpx;
}
.btn.ghost {
  background: #f2f3f5;
  color: #4b5056;
}
.btn.primary {
  background: #067ef9;
  color: #fff;
}

/* 二次确认弹窗（新增） */
.confirm-sheet {
  width: 100%;
  max-width: 600rpx;              /* 新增：最大宽度 */
  background: #fff;
  border-radius: 24rpx;           /* 改：全圆角（居中卡片） */
  padding: 36rpx 32rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}
.confirm-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  color: #1f2329;
  margin-bottom: 28rpx;
}
.confirm-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
  font-size: 28rpx;
}
.confirm-row .lbl {
  color: #6b7075;
  min-width: 120rpx;
  flex-shrink: 0;
}
.confirm-row .val {
  color: #1f2329;
  flex: 1;
  text-align: right;
}
.confirm-row.highlight .val {
  color: #f5503e;
  font-weight: 600;
  font-size: 30rpx;
}
.confirm-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
