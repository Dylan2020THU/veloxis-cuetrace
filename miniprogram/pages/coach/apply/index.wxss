.page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--text-weak);
  font-size: 28rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  overflow: hidden;
  background: #eef5ff;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #067ef9;
  font-size: 44rpx;
  font-weight: 600;
}

.avatar-title {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.muted {
  color: var(--text-weak);
  font-size: 26rpx;
}

.field {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid var(--border);
}

.field:last-child {
  border-bottom: none;
}

.field.column {
  align-items: flex-start;
  flex-direction: column;
  padding: 28rpx 0;
}

.field-label {
  width: 156rpx;
  color: var(--text);
  font-size: 28rpx;
  flex-shrink: 0;
}

.field-input,
.field-pick {
  flex: 1;
  color: var(--text);
  font-size: 28rpx;
  min-height: 60rpx;
  line-height: 60rpx;
}

.field-textarea {
  width: 100%;
  height: 136rpx;
  margin-top: 18rpx;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
}

.status-card {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
}

.status-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.status-pending .status-title {
  color: #067ef9;
}

.status-approved .status-title {
  color: #18a058;
}

.status-rejected .status-title,
.status-reason {
  color: #e54545;
}

.status-reason {
  font-size: 26rpx;
  line-height: 1.5;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--page-bg);
}

.submit-btn {
  height: 88rpx;
  border-radius: 16rpx;
  background: #067ef9;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-btn[disabled] {
  background: #b6cef5;
  color: #fff;
}

.submit-btn::after {
  border: none;
}
