.page {
  padding-bottom: 180rpx;
}

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
}

.avatar-ph {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f4f6f8;
  color: #067ef9;
  font-size: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ph-text {
  font-size: 22rpx;
  color: #8a9099;
}

.field {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.field.column {
  flex-direction: column;
  align-items: flex-start;
}

.field:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 30rpx;
  color: #1f2329;
  flex: 0 0 160rpx;
}

.field-input {
  flex: 1;
  font-size: 30rpx;
  text-align: right;
}

.field.column .field-input,
.field-textarea {
  text-align: left;
  width: 100%;
  margin-top: 16rpx;
  min-height: 80rpx;
  font-size: 28rpx;
}

.unit {
  font-size: 26rpx;
  color: #8a9099;
  margin-left: 12rpx;
}

.cert-tip {
  margin: 8rpx 0 20rpx;
}

.cert-grid {
  display: flex;
  flex-wrap: wrap;
}

.cert-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 16rpx 16rpx 0;
}

.cert-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.cert-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 30rpx;
}

.cert-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f4f6f8;
  color: #c4c9ce;
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-list {
  margin: 16rpx 0 24rpx;
}

.slot-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.slot-text {
  font-size: 28rpx;
  color: #1f2329;
}

.slot-del {
  font-size: 26rpx;
  color: #f5483b;
}

.slot-form {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.slot-pick {
  background: #f4f6f8;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.to {
  font-size: 26rpx;
  color: #8a9099;
  margin-right: 12rpx;
}

.slot-add {
  background: rgba(6, 126, 249, 0.12);
  color: #067ef9;
  border-radius: 12rpx;
  padding: 14rpx 28rpx;
  font-size: 28rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
}
