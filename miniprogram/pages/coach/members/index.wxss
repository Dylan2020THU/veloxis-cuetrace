.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 8rpx;
}

.count {
  font-size: 28rpx;
  color: #8a9099;
}

.add-link {
  font-size: 28rpx;
  color: #067ef9;
  font-weight: 500;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 56rpx;
  color: #d4d8dd;
  margin-bottom: 12rpx;
}

.member {
  display: flex;
  align-items: center;
  transition: background 0.2s;
}

/* 在练学员：底色为大川蓝（浅色调，文字保持深色） */
.member.training {
  background: rgba(6, 126, 249, 0.12);
}
.member.training .m-avatar {
  background: #ffffff;
  color: #067ef9;
}

/* 非在练学员：无底色 */
.member:not(.training) {
  background: transparent;
  box-shadow: none;
}

.m-avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

/* 在线绿点：头像框右下角 */
.online-dot {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #21c45d;
  border: 4rpx solid #ffffff;
}

.m-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(6, 126, 249, 0.12);
  color: #067ef9;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* 人像图片头像 */
image.m-avatar {
  background: #f0f1f3;
}

.m-avatar.small {
  width: 64rpx;
  height: 64rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.m-main {
  flex: 1;
}

.m-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
}

.arrow {
  color: #c4c9ce;
  font-size: 40rpx;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.sheet {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx;
  /* 自定义底栏是独立原生层、始终盖在页面之上（z-index 压不住）。
     直接把弹层抬到底栏(110rpx + 安全区)上方，确认按钮才不被遮挡。 */
  margin-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
}

.sheet-tip {
  margin-bottom: 24rpx;
}

.code-input {
  background: #f4f6f8;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.sheet-btn {
  width: 100%;
  height: 84rpx;
}

.cand {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.cand:last-child {
  border-bottom: none;
}

.cand-name {
  flex: 1;
  font-size: 30rpx;
  color: #1f2329;
}

.cand-link {
  font-size: 28rpx;
  color: #067ef9;
}

/* 已核验教学课时汇总 */
.lesson-banner {
  background: linear-gradient(135deg, #067ef9, #0a6fe0);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin: 0 0 20rpx;
}
.lesson-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.lesson-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}
