.page {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 24rpx calc(60rpx + env(safe-area-inset-bottom));
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--text-weak);
  font-size: 26rpx;
}

/* 状态切换 */
.tabs {
  display: flex;
  background: var(--bg-elev);
  border-radius: 16rpx;
  padding: 6rpx;
  margin: 24rpx 0;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 27rpx;
  color: var(--text-sub);
  border-radius: 12rpx;
}
.tab.active {
  background: var(--card-bg);
  color: var(--brand);
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(6, 126, 249, 0.18);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
}
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.shop-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}
.badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}
.badge--pending {
  color: #d97706;
  background: rgba(217, 119, 6, 0.12);
}
.badge--approved {
  color: #16a34a;
  background: rgba(22, 163, 74, 0.12);
}
.badge--rejected {
  color: #dc2626;
  background: rgba(220, 38, 38, 0.12);
}

.license {
  width: 100%;
  height: 300rpx;
  border-radius: 14rpx;
  background: var(--bg-elev);
  margin-bottom: 20rpx;
}

.kv {
  display: flex;
  padding: 10rpx 0;
  font-size: 27rpx;
}
.k {
  width: 160rpx;
  flex-shrink: 0;
  color: var(--text-weak);
}
.v {
  flex: 1;
  color: var(--text);
  word-break: break-all;
}
.v--reject {
  color: #dc2626;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 16rpx;
}
.btn-reject {
  color: #dc2626;
  background: rgba(220, 38, 38, 0.08);
  border: 2rpx solid rgba(220, 38, 38, 0.3);
}
.btn-approve {
  color: #fff;
  background: var(--brand);
}
