<view class="page theme-{{theme}}">
  <view class="store-bar" wx:if="{{stores.length > 0}}">
    <picker mode="selector" range="{{stores}}" range-key="name" value="{{storesIndex}}" bindchange="onStoreChange">
      <view class="store-picker">
        <text>{{currentStoreName || '全部门店'}}</text>
        <text class="arrow-icon">▼</text>
      </view>
    </picker>
  </view>

  <view class="header">
    <text class="count">本店教练 {{coaches.length}} 名</text>
    <view class="add-link" bindtap="openAdd">+ 添加教练</view>
  </view>

  <view wx:if="{{coaches.length === 0}}" class="empty card">
    <view class="empty-icon">○</view>
    <view class="muted">还没有添加教练，点击右上角添加</view>
  </view>

  <view wx:else class="list">
    <view
      class="coach card"
      wx:for="{{coaches}}"
      wx:key="openid"
      data-openid="{{item.openid}}"
      data-nickname="{{item.nickname}}"
      bindtap="viewCoach"
    >
      <view class="c-avatar-wrap">
        <view class="c-avatar">
          <image wx:if="{{item.avatar}}" class="c-avatar-img" src="{{item.avatar}}" mode="aspectFill"></image>
          <text wx:else>{{item.nickname[0]}}</text>
        </view>
        <view wx:if="{{item.online}}" class="online-dot"></view>
      </view>
      <view class="c-main">
        <view class="c-name">{{item.nickname}}</view>
        <view class="muted">球龄 {{item.playYears || 0}} 年 · 教龄 {{item.coachYears || 0}} 年 · {{item.pricePerMinute || 0}} 元/分</view>
        <view wx:if="{{item.intro}}" class="c-intro">{{item.intro}}</view>
      </view>
      <view class="c-del" data-openid="{{item.openid}}" data-nickname="{{item.nickname}}" catchtap="removeCoach">移除</view>
    </view>
  </view>
</view>

<view wx:if="{{showAdd}}" class="mask" bindtap="closeAdd">
  <view class="sheet" catchtap="">
    <view class="sheet-header">
      <view class="sheet-title">添加教练</view>
      <view class="sheet-scan" bindtap="scanAdd">扫码添加</view>
    </view>

    <block wx:if="{{cloudReady}}">
      <view class="muted sheet-tip">输入教练编码（教练的用户标识）进行添加</view>
      <input class="code-input" placeholder="教练编码" value="{{coachCode}}" bindinput="onCodeInput" />
      <button class="btn-primary sheet-btn" bindtap="addByCode">添加</button>
    </block>

    <block wx:else>
      <view class="muted sheet-tip">选择一名教练加入本店管理</view>
      <view wx:if="{{linkable.length === 0}}" class="muted">已无可添加的教练</view>
      <view class="cand" wx:for="{{linkable}}" wx:key="openid" data-openid="{{item.openid}}" bindtap="addDemo">
        <image wx:if="{{item.avatar}}" class="c-avatar small" src="{{item.avatar}}" mode="aspectFill"></image>
        <view wx:else class="c-avatar small">{{item.nickname[0]}}</view>
        <view class="cand-main">
          <text class="cand-name">{{item.nickname}}</text>
          <text class="muted">球龄 {{item.playYears}} 年 · {{item.pricePerMinute}} 元/分</text>
        </view>
        <text class="cand-link">添加</text>
      </view>
    </block>
  </view>
</view>
