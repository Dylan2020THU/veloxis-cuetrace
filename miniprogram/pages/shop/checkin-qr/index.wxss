.page {
  min-height: 100vh;
  background: #f4f6f8;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}
.loading {
  text-align: center;
  color: #9aa0a6;
  font-size: 28rpx;
  padding: 120rpx 0;
}
.qr-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(6, 126, 249, 0.06);
}
.store-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
  text-align: center;
}
.store-addr {
  font-size: 26rpx;
  color: #8a9099;
  margin-top: 10rpx;
  text-align: center;
}
.qr-img {
  width: 420rpx;
  height: 420rpx;
  margin: 40rpx 0;
}
.qr-ph {
  width: 420rpx;
  height: 420rpx;
  margin: 40rpx 0;
  border: 2rpx dashed #d4d7db;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}
.qr-ph-mark {
  font-size: 40rpx;
  font-weight: 700;
  color: #067ef9;
}
.qr-ph-tip {
  font-size: 22rpx;
  color: #9aa0a6;
  text-align: center;
  margin-top: 20rpx;
  line-height: 1.5;
}
.qr-ph-payload {
  font-size: 26rpx;
  color: #1f2329;
  background: #f4f6f8;
  border-radius: 10rpx;
  padding: 12rpx 24rpx;
  margin-top: 24rpx;
  font-family: "DIN Alternate", "Bahnschrift", monospace;
}
.qr-hint {
  font-size: 24rpx;
  color: #6b7075;
  text-align: center;
  line-height: 1.6;
  margin-top: 8rpx;
}
.qr-copy {
  margin-top: 32rpx;
  background: #067ef9;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 56rpx;
  border-radius: 44rpx;
}

/* 暗色 */
.theme-dark .page {
  background: #15171c;
}
.theme-dark .qr-card {
  background: #1f2329;
}
.theme-dark .store-name {
  color: #f0f1f3;
}
.theme-dark .qr-ph-payload {
  background: #2a2f37;
  color: #f0f1f3;
}
