<view class="page theme-{{theme}}">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 无品牌：空状态引导 -->
  <view wx:elif="{{!hasBrand}}" class="empty-card">
    <view class="empty-icon">+</view>
    <view class="empty-title">暂无球厅</view>
    <view class="empty-sub">添加您的品牌与门店，开启球厅管理</view>
    <button class="btn-primary" bindtap="goBrandAdd">添加品牌与门店</button>
  </view>

  <!-- 有品牌：概览 + 入口 -->
  <block wx:else>
    <view class="hero">
      <view class="hero-title">我的球厅</view>
      <view class="stats">
        <view class="stat">
          <view class="stat-num">{{storeCount}}</view>
          <view class="stat-label">门店数</view>
        </view>
        <view class="stat">
          <view class="stat-num">{{coachCount}}</view>
          <view class="stat-label">教练数</view>
        </view>
        <view class="stat">
          <view class="stat-num">{{totalHoursText}}</view>
          <view class="stat-label">总训练(h)</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="entry" bindtap="goHallStatus">
        <view class="entry-icon blue">态</view>
        <view class="entry-main">
          <view class="entry-title">球厅态势</view>
          <view class="muted">实时查看本店球桌使用状态</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="entry" bindtap="goMembers">
        <view class="entry-icon">会</view>
        <view class="entry-main">
          <view class="entry-title">会员名单</view>
          <view class="muted">查看打卡天数与训练时长</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="entry" bindtap="goCoaches">
        <view class="entry-icon">教</view>
        <view class="entry-main">
          <view class="entry-title">教练名单</view>
          <view class="muted">统一管理本店台球教练</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="entry" bindtap="goTableTypes">
        <view class="entry-icon">桌</view>
        <view class="entry-main">
          <view class="entry-title">球桌管理</view>
          <view class="muted">设置桌型名称与收费标准</view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="card">
      <view class="row" bindtap="goBrandAdd">
        <text class="row-label">添加门店</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="card">
      <button class="logout-btn" bindtap="logout">退出账号</button>
    </view>
  </block>
</view>
