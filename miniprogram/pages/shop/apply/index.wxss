.page {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx 24rpx calc(60rpx + env(safe-area-inset-bottom));
}

.loading {
  padding: 120rpx 0;
  text-align: center;
  color: var(--text-weak);
  font-size: 26rpx;
}

/* 顶部说明 */
.intro {
  padding: 16rpx 8rpx 28rpx;
}
.intro-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}
.intro-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--text-sub);
}

/* 驳回提示条 */
.reject-banner {
  background: rgba(229, 69, 69, 0.08);
  border: 2rpx solid rgba(229, 69, 69, 0.3);
  border-radius: 16rpx;
  padding: 22rpx 26rpx;
  margin-bottom: 24rpx;
}
.reject-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e54545;
}
.reject-banner-reason {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--text-sub);
}

/* 表单卡片 */
.form {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 8rpx 32rpx 24rpx;
}
.form-section-title {
  font-size: 26rpx;
  color: var(--text-weak);
  padding: 24rpx 0 12rpx;
}

/* 营业执照上传 */
.license-row {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: var(--bg-elev);
  border: 2rpx dashed var(--border);
}
.license-img {
  width: 100%;
  height: 100%;
}
.license-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.license-plus {
  font-size: 64rpx;
  line-height: 1;
  color: var(--text-weak);
}
.license-tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-weak);
}
.license-rechoose {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-weak);
  text-align: center;
}

/* 文本行 */
.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.form-row:last-child {
  border-bottom: none;
}
.form-label {
  font-size: 30rpx;
  color: var(--text);
  flex-shrink: 0;
  width: 160rpx;
}
.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}
.ph {
  color: var(--text-weak);
}

/* 底部备注 */
.form-note {
  margin: 24rpx 8rpx 0;
  font-size: 24rpx;
  color: var(--text-weak);
  text-align: center;
}

/* 提交区 */
.submit-wrap {
  margin-top: 32rpx;
  padding: 0 8rpx;
}
.btn-primary {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 36rpx 0 36rpx 0;
  box-shadow: 0 10rpx 28rpx rgba(6, 126, 249, 0.35);
}
.btn-primary.is-loading {
  opacity: 0.7;
}

/* 待审核状态卡 */
.status-card {
  margin-top: 80rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 64rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.status-icon {
  font-size: 88rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}
.status-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}
.status-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-sub);
}
.btn-ghost {
  margin-top: 40rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: var(--brand);
  background: transparent;
  border: 2rpx solid var(--brand);
  border-radius: 36rpx 0 36rpx 0;
}
.btn-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-weak);
  background: transparent;
  line-height: 1.8;
}
.btn-text::after {
  border: none;
}
