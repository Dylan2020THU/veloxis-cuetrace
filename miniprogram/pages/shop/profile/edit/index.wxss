.page {
  min-height: 100vh;
  padding: 24rpx 0 calc(60rpx + env(safe-area-inset-bottom));
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--text-weak);
  font-size: 26rpx;
}

.form {
  background: var(--card-bg);
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 8rpx 32rpx;
}
.form-section-title {
  font-size: 26rpx;
  color: var(--text-weak);
  padding: 24rpx 0 8rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.form-row:last-child {
  border-bottom: none;
}
.form-row--col {
  flex-direction: column;
  align-items: stretch;
}
.form-label {
  font-size: 30rpx;
  color: var(--text);
  flex-shrink: 0;
}
.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text);
  margin-left: 24rpx;
}
.form-textarea {
  width: 100%;
  height: 140rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: var(--text);
}

.value-area {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
  margin-left: 24rpx;
}
.location-area {
  gap: 16rpx;
}
.addr-input {
  margin-left: 0;
}
.loc-btn {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--brand);
  border: 1rpx solid var(--brand);
  border-radius: 24rpx;
  padding: 6rpx 22rpx;
}

.logo-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: var(--bg-elev);
}
.logo-ph {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: rgba(6, 126, 249, 0.12);
  color: var(--brand);
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.arrow {
  color: var(--text-weak);
  font-size: 36rpx;
  margin-left: 12rpx;
}

.entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}
.entry-title {
  font-size: 30rpx;
  color: var(--text);
}

.save-btn {
  width: calc(100% - 48rpx);
  margin: 48rpx 24rpx 0;
  height: 88rpx;
}

.empty-card {
  margin: 24rpx;
  text-align: center;
  padding: 60rpx 32rpx;
}
.create-btn {
  width: 60%;
  margin: 32rpx auto 0;
  height: 84rpx;
}
