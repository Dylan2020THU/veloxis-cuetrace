<view class="page theme-{{theme}}">
  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:else>
    <!-- 无门店：引导去创建 -->
    <view wx:if="{{!hasStore}}" class="card empty-card">
      <view class="muted">你还没有创建球厅门店</view>
      <button class="btn-primary create-btn" bindtap="goCreateStore">去创建门店</button>
    </view>

    <block wx:else>
      <view class="form">
        <view class="form-section-title">球厅信息</view>

        <!-- Logo -->
        <view class="form-row avatar-row" bindtap="chooseLogo">
          <text class="form-label">球厅 Logo</text>
          <view class="value-area">
            <image wx:if="{{logo}}" class="logo-img" src="{{logo}}" mode="aspectFill" />
            <view wx:else class="logo-ph">{{shopName ? shopName[0] : '球'}}</view>
            <text class="arrow">›</text>
          </view>
        </view>

        <!-- 球厅名称 -->
        <view class="form-row">
          <text class="form-label">球厅名称</text>
          <input class="form-input" placeholder="请输入" value="{{shopName}}" bindinput="onShopNameInput" maxlength="30" />
        </view>

        <!-- 门店名称 -->
        <view class="form-row">
          <text class="form-label">门店名称</text>
          <input class="form-input" placeholder="请输入" value="{{storeName}}" bindinput="onStoreNameInput" maxlength="30" />
        </view>

        <!-- 地址 -->
        <view class="form-row">
          <text class="form-label">门店地址</text>
          <view class="value-area location-area">
            <input class="form-input addr-input" placeholder="请输入或定位" value="{{address}}" bindinput="onAddressInput" />
            <text class="loc-btn" bindtap="chooseLocation">定位</text>
          </view>
        </view>

        <!-- 营业时间 -->
        <view class="form-row">
          <text class="form-label">营业时间</text>
          <input class="form-input" placeholder="如 10:00-24:00" value="{{businessHours}}" bindinput="onHoursInput" maxlength="30" />
        </view>

        <!-- 简介 -->
        <view class="form-row form-row--col">
          <text class="form-label">球厅简介</text>
          <textarea class="form-textarea" placeholder="一句话介绍你的球厅" value="{{intro}}" bindinput="onIntroInput" maxlength="120" />
        </view>
      </view>

      <view class="form" style="margin-top: 24rpx;">
        <view class="entry" bindtap="goTableTypes">
          <text class="entry-title">桌型与价格</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <button class="btn-primary save-btn" bindtap="save" disabled="{{submitting}}">
        {{ submitting ? '保存中...' : '保存' }}
      </button>
    </block>
  </block>
</view>
