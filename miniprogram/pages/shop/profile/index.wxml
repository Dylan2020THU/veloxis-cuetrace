<view class="page theme-{{theme}}">
  <!-- 头部 -->
  <view class="hero">
    <image wx:if="{{logo}}" class="hero-logo" src="{{logo}}" mode="aspectFill"></image>
    <view wx:else class="hero-logo hero-logo--ph">{{shopName[0]}}</view>
    <view class="hero-name">{{shopName}}</view>
    <view class="hero-badge">强化杆迹 · 店主</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:else>
    <!-- 经营概览 -->
    <view class="card">
      <view class="card-title">球厅概览</view>
      <view class="metrics">
        <view class="metric">
          <view class="metric-num">{{storeCount}}</view>
          <view class="metric-label">门店数</view>
        </view>
        <view class="metric">
          <view class="metric-num">{{coachCount}}</view>
          <view class="metric-label">教练数</view>
        </view>
        <view class="metric">
          <view class="metric-num">{{memberCount}}</view>
          <view class="metric-label">会员数</view>
        </view>
        <view class="metric">
          <view class="metric-num"><text class="cur">¥</text>{{todayRevenue}}</view>
          <view class="metric-label">今日营收</view>
        </view>
      </view>
    </view>

    <!-- 门店列表 -->
    <view class="card">
      <view class="card-head">
        <text class="card-title">门店</text>
        <text class="card-more" bindtap="goStores">门店管理 ›</text>
      </view>
      <view wx:if="{{stores.length === 0}}" class="empty">
        <view class="muted">还没有门店，去「门店管理」创建</view>
      </view>
      <view wx:else>
        <view class="store-row" wx:for="{{stores}}" wx:key="_id">
          <view class="store-main">
            <view class="store-name">{{item.name}}</view>
            <view class="muted store-addr">{{item.address}}</view>
            <view class="muted" wx:if="{{item.businessHours}}">营业时间 {{item.businessHours}}</view>
          </view>
          <view class="store-tail">{{item.tableTypeCount}} 种桌型</view>
        </view>
      </view>
    </view>

    <!-- 操作 -->
    <view class="card actions">
      <view class="entry" bindtap="goEdit">
        <text class="entry-title">编辑球厅信息</text>
        <text class="arrow">›</text>
      </view>
      <view class="entry" bindtap="goTableTypes">
        <text class="entry-title">桌型与价格</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </block>
</view>
