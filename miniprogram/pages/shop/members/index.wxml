<view class="page theme-{{theme}}">
  <view class="store-bar" wx:if="{{stores.length > 0}}">
    <picker mode="selector" range="{{stores}}" range-key="name" value="{{storesIndex}}" bindchange="onStoreChange">
      <view class="store-picker">
        <text>{{currentStoreName || '全部门店'}}</text>
        <text class="arrow-icon">▼</text>
      </view>
    </picker>
  </view>

  <view class="header">
    <text class="count">本店会员 {{members.length}} 名</text>
    <view class="add-link" bindtap="openAdd">+ 添加会员</view>
  </view>

  <view class="summary card">
    <view class="sum-item">
      <view class="sum-num">{{members.length}}</view>
      <view class="muted">本店会员</view>
    </view>
    <view class="sum-item">
      <view class="sum-num">{{totalDays}}</view>
      <view class="muted">累计打卡天</view>
    </view>
    <view class="sum-item">
      <view class="sum-num">{{totalHoursText}}</view>
      <view class="muted">累计时长(h)</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{members.length === 0}}" class="empty card">
    <view class="empty-icon">○</view>
    <view class="muted">本店暂无会员训练记录</view>
  </view>

  <view wx:else class="card">
    <view class="table-head">
      <text class="th name">会员</text>
      <text class="th">打卡天数</text>
      <text class="th">训练时长</text>
    </view>
    <view class="trow" wx:for="{{members}}" wx:key="openid">
      <view
        class="td name"
        data-openid="{{item.openid}}"
        data-nickname="{{item.nickname}}"
        bindtap="viewMember"
      >
        <view class="m-avatar-wrap">
          <image wx:if="{{item.avatar}}" class="m-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="m-avatar">{{item.nickname[0]}}</view>
          <view wx:if="{{item.online}}" class="online-dot"></view>
        </view>
        <text class="m-name">{{item.nickname}}</text>
      </view>
      <text class="td days">{{item.checkinDays}} 天</text>
      <text class="td hours">{{item.hoursText}} h</text>
    </view>
  </view>
</view>

<!-- 添加会员弹层（扫码 / 输入编码） -->
<view wx:if="{{showAdd}}" class="mask" bindtap="closeAdd">
  <view class="sheet" catchtap="noop">
    <view class="sheet-header">
      <view class="sheet-title">添加会员</view>
      <view class="sheet-scan" bindtap="scanAdd">扫码添加</view>
    </view>
    <view class="muted sheet-tip">输入会员编码添加，或点右上角「扫码添加」</view>
    <input class="code-input" placeholder="会员编码（如 CT-XXXXXX）" value="{{memberCode}}" bindinput="onCodeInput" />
    <button class="btn-primary sheet-btn" bindtap="addByCode">添加</button>

    <block wx:if="{{!cloudReady && linkable.length}}">
      <view class="muted sheet-tip cand-tip">或从会员列表中选择</view>
      <scroll-view scroll-y="true" class="cand-list">
        <view class="cand" wx:for="{{linkable}}" wx:key="openid" data-openid="{{item.openid}}" bindtap="addDemo">
          <image wx:if="{{item.avatar}}" class="m-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="m-avatar">{{item.nickname[0]}}</view>
          <view class="cand-main">
            <text class="cand-name">{{item.nickname}}</text>
            <text class="muted">{{item.level}}</text>
          </view>
          <text class="cand-link">添加</text>
        </view>
      </scroll-view>
    </block>
  </view>
</view>

<paywall id="paywall"></paywall>
