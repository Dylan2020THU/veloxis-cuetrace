.summary {
  display: flex;
}

.sum-item {
  flex: 1;
  text-align: center;
}

.sum-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #067ef9;
  line-height: 1.2;
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: #8a9099;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 56rpx;
  color: #d4d8dd;
  margin-bottom: 12rpx;
}

.table-head {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f2f4;
}

.th {
  flex: 1;
  font-size: 24rpx;
  color: #8a9099;
  text-align: center;
}

.th.name,
.td.name {
  flex: 1.4;
  text-align: left;
}

.trow {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.trow:last-child {
  border-bottom: none;
}

.td {
  flex: 1;
  font-size: 28rpx;
  text-align: center;
  color: #1f2329;
}

.td.name {
  display: flex;
  align-items: center;
}

.m-avatar-wrap {
  position: relative;
  margin-right: 16rpx;
}

/* 在线绿点：头像框右下角（与教练端「我的学员」一致，适配 60rpx 小头像） */
.online-dot {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #21c45d;
  border: 3rpx solid #ffffff;
}

.m-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(6, 126, 249, 0.12);
  color: #067ef9;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.m-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #067ef9;
}

.td.hours {
  color: #067ef9;
  font-weight: 600;
}
