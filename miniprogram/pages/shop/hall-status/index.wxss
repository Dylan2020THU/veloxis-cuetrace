.page {
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  background: #f4f6f8;
  min-height: 100vh;
}

.store-bar {
  padding: 16rpx 32rpx;
  background: #fff;
}
.store-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f4f6f8;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 30rpx;
  color: #1f2329;
}
.arrow-icon {
  font-size: 22rpx;
  color: #8a9099;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-group {
  margin-bottom: 16rpx;
}
.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #8f9bb3;
  margin-bottom: 10rpx;
  display: block;
  font-weight: 500;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  font-size: 26rpx;
  color: #505a6e;
  background: #f0f2f5;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.filter-chip.active {
  color: var(--card-color, #067ef9);
  background: color-mix(in srgb, var(--card-color, #067ef9) 10%, #fff);
  border-color: var(--card-color, #067ef9);
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx 12rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #8f9bb3;
}

.stats-text.occupied-count {
  color: #ff6b35;
  font-weight: 600;
}

.refresh-btn {
  font-size: 28rpx;
  color: #067ef9;
  padding: 8rpx 20rpx;
  border: 2rpx solid #067ef9;
  border-radius: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: #9aa0a6;
  text-align: center;
  line-height: 1.8;
}

/* 2列网格 */
.table-grid {
  display: flex;
  flex-wrap: wrap;
  margin-right: -10rpx;
}

/* 球台卡片 - 书签式设计 */
.table-card {
  width: calc(50% - 10rpx);
  margin-right: 10rpx;
  margin-bottom: 28rpx;
  border-radius: 20rpx;
  overflow: visible;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  flex-direction: column;
  border: none;
  background: #fff;
  position: relative;
  padding-top: 0;
  transition: box-shadow 0.3s ease;
}

/* 卡片内容区（含圆角白色底） */
.table-card-inner {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  flex-direction: column;
  flex: 1;
  position: relative;
}

/* 书签条：压在卡片上方，两角圆弧 */
.bookmark-strip {
  width: 100%;
  height: 12rpx;
  border-radius: 20rpx 20rpx 0 0;
  margin-bottom: -4rpx;
  position: relative;
  z-index: 1;
}

/* 占用时加深阴影 + 品牌色填充（透明度5%） */
.table-card.occupied .table-card-inner {
  box-shadow: 0 6rpx 28rpx rgba(0, 0, 0, 0.13);
}

/* 品牌色色块叠加层 */
.table-card.occupied .table-card-inner::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--card-color, #067ef9);
  opacity: 0.00;
  pointer-events: none;
  border-radius: 20rpx;
  z-index: 0;
}

/* 卡片头部 */
.card-header {
  padding: 16rpx 18rpx 10rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* 品牌色分隔线（已隐藏，改为书签条） */
.brand-divider {
  display: none;
}

.table-info {
  display: flex;
  flex-direction: column;
}

.table-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.table-brand {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-top: 2rpx;
  font-weight: 500;
}

/* 状态标签 */
.status-badge {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 6rpx;
}

.status-badge.idle .status-dot {
  background: #34c759;
  box-shadow: 0 0 0 3rpx rgba(52, 199, 89, 0.2);
}

.status-badge.occupied .status-dot {
  background: #067ef9;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-text {
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.idle .status-text {
  color: #34c759;
}

.status-badge.occupied .status-text {
  color: #067ef9;
}

.waiting-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #9aa0a6;
  padding: 8rpx 0 4rpx;
  font-style: italic;
}

/* 球员区域 */
.players-zone {
  padding: 14rpx 16rpx;
  flex: 1;
  min-height: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.idle-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #c4c9ce;
  padding: 8rpx 0;
}

/* 球员行：水平布局 */
.player-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.player-avatar-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.player-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f1f3;
}

.player-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--card-color, #067ef9);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coach-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: #ff9500;
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.player-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding-left: 10rpx;
}

.player-name {
  font-size: 26rpx;
  color: #1f2329;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.coach-time {
  font-size: 22rpx;
  color: #067ef9;
  font-weight: 600;
}

/* 操作按钮 */
.card-action {
  padding: 12rpx 16rpx 16rpx;
}

.action-btn {
  width: 100%;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-use {
  background: var(--card-color, #067ef9);
  color: #fff;
}

.btn-end {
  background: #fff;
  color: #e54545;
  border: 2rpx solid #e54545;
}

/* 桌型收费信息栏 */
.table-price-bar {
  padding: 0 16rpx 8rpx;
  display: flex;
  align-items: center;
}

.price-bar-text {
  font-size: 22rpx;
  color: #5a6570;
  font-weight: 600;
}

/* 底部已开桌时长 */
.table-elapsed {
  padding: 0 16rpx 4rpx;
  display: flex;
  align-items: center;
}

.elapsed-text {
  font-size: 24rpx;
  color: #067ef9;
  font-weight: 700;
}

/* 当前收入 */
.table-revenue {
  padding: 0 16rpx 8rpx;
  display: flex;
  align-items: center;
}

.revenue-text {
  font-size: 22rpx;
  color: #ff7a00;
  font-weight: 700;
}
