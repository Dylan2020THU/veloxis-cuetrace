.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #f0f1f3;
  z-index: 1000;
}

.tab-bar.dark {
  background: #15171c;
  border-top-color: #2a2d35;
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 店主端选中态：顶部黄铜菱形指示点（绝对定位，不挤压图标布局） */
.tab-diamond {
  position: absolute;
  top: 6rpx;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  background: #c9a24b;
  border-radius: 2rpx;
  transform: translateX(-50%) rotate(45deg);
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
  background-color: #9aa0a6;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: 100% 100%;
  mask-size: 100% 100%;
}

.tab-bar.dark .tab-icon {
  background-color: #7a818c;
}

.tab-item.active .tab-icon {
  background-color: #067ef9;
}

.tab-text {
  font-size: 22rpx;
  color: #9aa0a6;
}

.tab-bar.dark .tab-text {
  color: #7a818c;
}

.tab-item.active .tab-text {
  color: #067ef9;
  font-weight: 600;
}
